interface ConcatString
service concatStrings (
)
properties {
    favorite: false;
    deprecated: false;
    visible: public;
    reuse: public;
    stateless: true;
    cacheResults: false;
    cacheExpire: 15;
    prefetch: false;
    prefetchActivation: 1;
    pipelineDebug: None;
    allowedHttpMethods: [TRACE, HEAD, DELETE, POST, GET, OPTIONS, PUT, PATCH];
    maxRetryAttempts: 0;
    retryInterval: 0;
    enableAuditing: never;
    logOn: Error only;
    includePipeline: never;
    circuitBreakerEnabled: false;
    failureEvent: Exception only;
    timeoutPeriod: 60;
    cancelThreadOnTimeout: false;
    failureThreshold: 5;
    failurePeriod: 60;
    circuitOpenAction: Throw exception;
    circuitResetPeriod: 300;
    concurrencyEnabled: false;
    maxConcurrentRequests: 20;
    validateInput: false;
    validateOutput: false;
}
{
    INVOKE pub.string:concat {
        validateInput: false
        validateOutput: false
        input {
            mapTarget {
                String inString1;
                String inString2;
            }
            set `inString1` = "Arti";
            set `inString2` = "Khare";
        }
    }
}
